{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pasus Miner",
  "version": "0.1.7",
  "identifier": "com.pasus.miner",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Pasus Miner",
        "width": 1440,
        "height": 940,
        "resizable": true,
        "minWidth": 1080,
        "minHeight": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": {
      "../tools/": "tools/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI3RDI4RDI0RDUzMkIxMkMKUldRc3NUTFZKSTNTSjV6TDB4L2hzYVRuVThmK0RFWktlMFdDQWtaTG5ZVVJLb0NveVpxK0EveHgK",
      "endpoints": [
        "https://github.com/brentishere41848/pasusminer/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
